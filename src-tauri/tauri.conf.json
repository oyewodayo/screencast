{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Briefcast",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": false,
        "scope": ["$VIDEO/Briefcast/**", "$TEMP/**"]
      },
      "protocol": {
        "all": false,
        "asset": true,
        "assetScope": ["**"]
      },
      "path": {
        "all": false
      },
      "dialog": {
        "all": false,
        "message": true,
        "open": true
      },
      "notification": {
        "all": false
      },
      "globalShortcut": {
        "all": true
      },
      "window": {
        "all": false,
        "create": true,
        "close": true,
        "hide": true,
        "show": true,
        "setFocus": true,
        "startDragging": true,
        "setFullscreen": true
      },
      "os": {
        "all": false
      },
      "shell": {
        "all": false,
        "open": true
      }
    },
    "windows": [
      {
        "title": "Briefcast",
        "width": 900,
        "height": 600,
        "minWidth": 850,
        "minHeight": 600
        
      },
      {
        "label": "recording-overlay",
        "title": "Recording",
        "url": "/recording-overlay",
        "width": 350,
        "height": 100,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "focus": false
      },
      {
        "label": "screenshot-overlay",
        "title": "Screenshot",
        "url": "/screenshot-overlay",
        "width": 300,
        "height": 120,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "focus": false
      }

    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; media-src 'self' asset: https://asset.localhost; frame-src 'self' asset: https://asset.localhost; connect-src 'self' asset: https://asset.localhost; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "resources": [
        "binaries/ffmpeg/*"
      ],
      "identifier": "com.briefscan.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
