{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "/"
  },
  "package": {
    "productName": "screencast",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true, 
      "path": {
        "all": true      
      },
      "dialog": {
        "all": true, 
        "ask": true, 
        "confirm": true, 
        "message": true, 
        "open": true, 
        "save": true 
      },
      "notification": {
        "all": true 
      },
      "window": {
        "all": true
      }, 
      "os": {
        "all": true
      },   
      "shell": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": true,
        "scope":["**"]  
      }
    },
    "windows": [
      {
        "title": "screencast",
        "width": 800,
        "height": 600,
        "minWidth": 850,
        "minHeight": 600
        
      }
  
    ],
    "security": {
      "csp": "default-src blob: data: filesystem: ws: http: https: 'unsafe-eval' 'unsafe-inline'"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "resources": [
        "binaries/ffmpeg/*"
      ],
      "identifier": "com.tauri.dev",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
