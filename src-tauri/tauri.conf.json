{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Briefcast",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true, 
      "fs": {
        "all": true,
        "readFile": true,
        "scope": ["$VIDEO/**", "**"]
      },
       "protocol": {
        "all": true,
        "asset": true,
        "assetScope": ["**"]
      },
      "path": {
        "all": true      
      },
      "dialog": {
        "all": true, 
        "ask": true, 
        "confirm": true, 
        "message": true, 
        "open": true, 
        "save": true 
      },
      "notification": {
        "all": true 
      },
      "window": {
        "all": true
      }, 
      "os": {
        "all": true
      },   
      "shell": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": true,
        "scope":["**"]  
      }
    },
    "windows": [
      {
        "title": "Briefcast",
        "width": 800,
        "height": 600,
        "minWidth": 850,
        "minHeight": 600
        
      },
      {
        "label": "recording-overlay",
        "title": "Recording",
        "url": "/recording-overlay",
        "width": 350,
        "height": 100,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "focus": false
      }
  
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "resources": [
        "binaries/ffmpeg/*"
      ],
      "identifier": "com.briefscan.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
