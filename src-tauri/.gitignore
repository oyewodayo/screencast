# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# FFmpeg binaries (large files, platform-specific)
/src-tauri/binaries/
/src-tauri/binaries/ffmpeg/
/src-tauri/binaries/ffmpeg/*.exe
/src-tauri/binaries/ffmpeg/ffmpeg
/src-tauri/binaries/ffmpeg/ffprobe
/src-tauri/binaries/ffmpeg/ffplay
/src-tauri/binaries/bin/
/src-tauri/binaries/bin/ffmpeg/
/src-tauri/binaries/bin/ffmpeg/*.exe
/src-tauri/binaries/bin/ffmpeg/ffmpeg
/src-tauri/binaries/bin/ffmpeg/ffprobe
/src-tauri/binaries/bin/ffmpeg/ffplay


# Alternatively, ignore all binaries but keep the directory structure
# src-tauri/binaries/**/*
# !src-tauri/binaries/**/.gitkeep