# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# FFmpeg binaries (large files, platform-specific)
/binaries/
/binaries/ffmpeg/
/binaries/ffmpeg/*.exe
/binaries/ffmpeg/ffmpeg
/binaries/ffmpeg/ffprobe
/binaries/ffmpeg/ffplay
/binaries/bin/
/binaries/bin/ffmpeg/
/binaries/bin/ffmpeg/*.exe
/binaries/bin/ffmpeg/ffmpeg
/binaries/bin/ffmpeg/ffprobe
/binaries/bin/ffmpeg/ffplay


# Alternatively, ignore all binaries but keep the directory structure
# src-tauri/binaries/**/*
# !src-tauri/binaries/**/.gitkeep